{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "types": ["svelte", "vite/client"],
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "moduleDetection": "force",

    "paths": {
      "$/*": ["./src/*"],
      "$lib/*": ["./src/lib/*"],
      "$utils/*": ["./src/utils/*"],
      "$img/*": ["./src/assets/images/*"],
      "$type/*": ["./src/types/*"],
      "$layout/*": ["./src/layout/*"],
      "$pages/*": ["./src/pages/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "src/**/*.svelte.ts",
    "src/**/*.svelte.js"
  ]
}
